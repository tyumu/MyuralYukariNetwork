# MyuralYukariNetwork 開発用サンプル環境変数
# 使い方:
# - このファイルを .env としてコピーして使う
# - Go backend と Python sidecar は起動時に .env を読む
# - start-dev.ps1 / env.ps1 / env.sh は手動起動を楽にする補助ファイル

# Go Backend / 共通設定
# Windows / Linux で共通
SERVER_PORT=8000
SERVER_HOST=localhost
LOG_LEVEL=debug
DEV_MODE=true
FRONTEND_ORIGIN=http://localhost:1420

# Go Backend <-> Python Sidecar gRPC エンドポイント
# Windows 開発既定: 127.0.0.1:50051
# Linux/macOS 例: unix:///tmp/myural_yukari_memory.sock
MEMORY_GRPC_ENDPOINT=127.0.0.1:50051

# llama.cpp / OpenAI 互換 API 設定
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
CHAT_MODEL=unsloth/gemma-4-E4B-it-GGUF
EMBED_MODEL=nomic-embed-text:latest-num-gpu0

# MemU (PostgreSQL) 設定
# 必要に応じて自分の DB に合わせる
POSTGRES_DSN=postgresql://postgres:1210@127.0.0.1:5433/memu_db
RETRIEVAL_TOP_K=5

# フロントエンド (Vite/Tauri) の API 接続先
VITE_API_BASE_URL=http://localhost:8000

# Sidecar ヘルスチェック設定
# true: 埋め込み実行まで検証 / false: 初期化確認のみ
SIDECAR_HEALTH_STRICT=false