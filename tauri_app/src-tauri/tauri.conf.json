{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Myural Yukari Desktop",
  "version": "0.1.0",
  "identifier": "com.myural.yukari.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Myural Yukari Desktop",
        "width": 1000,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
